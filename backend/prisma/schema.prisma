// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MembershipRole {
  SUPER_ADMIN
  COMMITTEE_ADMIN
  SECURITY
  RESIDENT
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum PostType {
  GENERAL
  QUESTION
  RECOMMENDATION
  LOST_FOUND
}

enum ListingCategory {
  ITEM_SALE
  ITEM_FREE
  ITEM_RENT
  PROPERTY_SALE
  PROPERTY_RENT
}

enum ListingStatus {
  ACTIVE
  CLOSED
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())

  // Shareable/searchable handle, auto-generated once at registration (see
  // UsersService.generateUsername) - lets people find each other the way a
  // phone number-only lookup never could (nobody shares raw phone numbers).
  username String? @unique

  // Location profile - filled in once, right after login, via
  // PATCH /users/me/location. Nullable so login still works before it's set.
  addressLine String?
  city        String?
  state       String?
  pincode     String?
  area        String?
  latitude    Float?
  longitude   Float?

  // Web Push registration token for emergency alerts (PATCH /users/me/fcm-token).
  // Single most-recent token per user - fine at this stage, multi-device is later.
  fcmToken String?

  // Platform-wide admin (see backend/src/admin) - independent of any
  // per-society Membership role. Manually granted, not self-service.
  // Super admins log in with email+password (POST /admin/login) instead of
  // the consumer phone-OTP flow - passwordHash is only ever set for them.
  isSuperAdmin Boolean   @default(false)
  isSuspended  Boolean   @default(false)
  lastLoginAt  DateTime?
  email        String?   @unique
  passwordHash String?

  memberships       Membership[]
  authoredNotices   Notice[]
  raisedComplaints  Complaint[]
  posts             Post[]
  comments          Comment[]
  polls             Poll[]
  pollVotes         PollVote[]
  events            Event[]
  listings          Listing[]
  eventRsvps        EventRsvp[]
  areaPosts         AreaPost[]
  areaPostInterests AreaPostInterest[]
  areaPostSaves     AreaPostSave[]
  areaPostComments  AreaPostComment[]
  following         Follow[] @relation("Follower")
  followers         Follow[] @relation("Following")
  sentMessages      Message[] @relation("MessageSender")
  receivedMessages  Message[] @relation("MessageReceiver")
  stories           Story[]
  storyViews        StoryView[]
  storyReactions    StoryReaction[]
  reels             Reel[]
  reelLikes         ReelLike[]
  reelComments      ReelComment[]
  campaigns         Campaign[]

  @@index([area])
}

// --- Follow graph: directed, no approval needed (unlike society Membership).
// followerId follows followingId.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model Society {
  id          String   @id @default(cuid())
  name        String
  addressLine String
  city        String
  state       String
  pincode     String
  createdAt   DateTime @default(now())

  units       Unit[]
  memberships Membership[]
  notices     Notice[]
  complaints  Complaint[]
  posts       Post[]
  polls       Poll[]
  events      Event[]
  listings    Listing[]

  @@index([city, pincode])
}

model Unit {
  id         String  @id @default(cuid())
  societyId  String
  unitNumber String
  blockName  String?

  society     Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  memberships Membership[]
  complaints  Complaint[]

  @@unique([societyId, unitNumber])
}

model Membership {
  id        String            @id @default(cuid())
  userId    String
  societyId String
  unitId    String?
  role      MembershipRole
  status    MembershipStatus  @default(PENDING)
  createdAt DateTime          @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  unit    Unit?   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, societyId])
}

model Notice {
  id        String   @id @default(cuid())
  societyId String
  authorId  String
  title     String
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([societyId])
}

model Complaint {
  id          String          @id @default(cuid())
  societyId   String
  raisedById  String
  unitId      String?
  category    String
  description String
  status      ComplaintStatus @default(OPEN)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  society  Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  raisedBy User    @relation(fields: [raisedById], references: [id], onDelete: Cascade)
  unit     Unit?   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([societyId])
}

model Post {
  id        String   @id @default(cuid())
  societyId String
  authorId  String
  type      PostType @default(GENERAL)
  title     String?
  body      String
  createdAt DateTime @default(now())

  society  Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([societyId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Poll {
  id        String   @id @default(cuid())
  societyId String
  authorId  String
  question  String
  createdAt DateTime @default(now())

  society Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  author  User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([societyId])
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  label  String

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]
}

model PollVote {
  id           String   @id @default(cuid())
  pollId       String
  pollOptionId String
  userId       String
  createdAt    DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
}

model Event {
  id          String   @id @default(cuid())
  societyId   String
  authorId    String
  title       String
  description String
  location    String
  startAt     DateTime
  createdAt   DateTime @default(now())

  society Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  author  User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  rsvps   EventRsvp[]

  @@index([societyId])
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus
  createdAt DateTime   @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Listing {
  id          String          @id @default(cuid())
  societyId   String
  sellerId    String
  category    ListingCategory
  title       String
  description String
  price       Float?
  imageUrls   String[]
  status      ListingStatus   @default(ACTIVE)
  createdAt   DateTime        @default(now())

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  seller  User    @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([societyId])
}

// --- Area feed (locality posts: updates, shops, sports invites, help
// requests, social events, safety alerts, service requests) - authenticated,
// owned by User.

enum AreaPostKind {
  UPDATE
  SHOP
  SPORTS_INVITE
  HELP_REQUEST
  SOCIAL_EVENT
  SAFETY_ALERT
  SERVICE_REQUEST
  EMERGENCY_SOS
}

enum AreaPostVisibility {
  PINCODE_ONLY
  NEARBY
  ALL_INDIA
}

model AreaPost {
  id          String             @id @default(cuid())
  userId      String
  area        String
  pincode     String?
  latitude    Float?
  longitude   Float?
  kind        AreaPostKind
  visibility  AreaPostVisibility @default(NEARBY)
  // Author-chosen broadcast radius in km for NEARBY-visibility posts (null =
  // legacy exact-area-string matching in listForArea, unaffected).
  radiusKm    Float?
  title       String
  description String
  imageUrls   String[]
  videoUrl    String?
  videoTrimStart Float?
  videoTrimEnd   Float?
  audioUrl    String?
  location    String?
  sportName   String?
  serviceType String?
  businessCategory String?
  offerText   String?
  businessHours String?
  emergencyCategory String?
  activityTime    String?
  partnersNeeded  Int?
  createdAt   DateTime           @default(now())

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests AreaPostInterest[]
  saves     AreaPostSave[]
  comments  AreaPostComment[]

  @@index([area])
  @@index([latitude, longitude])
}

model AreaPostInterest {
  id         String   @id @default(cuid())
  areaPostId String
  userId     String
  createdAt  DateTime @default(now())

  areaPost AreaPost @relation(fields: [areaPostId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([areaPostId, userId])
}

model AreaPostSave {
  id         String   @id @default(cuid())
  areaPostId String
  userId     String
  createdAt  DateTime @default(now())

  areaPost AreaPost @relation(fields: [areaPostId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([areaPostId, userId])
}

model AreaPostComment {
  id         String   @id @default(cuid())
  areaPostId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  areaPost AreaPost @relation(fields: [areaPostId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([areaPostId])
}

// --- Private 1:1 messaging (no read receipts / conversation entity - a
// thread is just "all messages between these two users").

enum MessageKind {
  TEXT
  STICKER
}

model Message {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  body       String
  kind       MessageKind @default(TEXT)
  createdAt  DateTime    @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
}

// --- Stories: 24h-expiring photo/video updates, visible to same-area users.

enum StoryMediaType {
  IMAGE
  VIDEO
}

model Story {
  id        String         @id @default(cuid())
  userId    String
  mediaUrl  String
  mediaType StoryMediaType
  audioUrl  String?
  area      String
  createdAt DateTime       @default(now())
  expiresAt DateTime

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  views     StoryView[]
  reactions StoryReaction[]

  @@index([area])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  viewerId  String
  createdAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerId])
}

model StoryReaction {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
}

// --- Reels: permanent short vertical videos (unlike 24h-expiring Stories),
// browsed as their own dedicated full-screen swipe feed.

model Reel {
  id        String   @id @default(cuid())
  userId    String
  videoUrl  String
  caption   String?
  createdAt DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes    ReelLike[]
  comments ReelComment[]

  @@index([createdAt])
}

model ReelLike {
  id        String   @id @default(cuid())
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
}

model ReelComment {
  id        String   @id @default(cuid())
  reelId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  reel   Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([reelId])
}

// --- Ad campaigns: self-serve promoted posts, paid via Razorpay, shown as
// "Sponsored" cards in the area feed to whichever audience the campaign
// targets. Payment is server-verified (webhook signature), never trusted
// from the client alone.

enum CampaignObjective {
  SALES
  DOWNLOADS
  AWARENESS
  ENGAGEMENT
}

enum CampaignTargetType {
  NEARBY // targetLatitude/Longitude/RadiusKm
  PINCODE // targetPincode
  STATES // targetStates (one or more)
  ALL_INDIA
}

enum CampaignStatus {
  DRAFT // created, payment not started
  PENDING_PAYMENT // checkout link issued, awaiting Razorpay confirmation
  ACTIVE // paid, currently shown to its target audience
  COMPLETED // ran its course (endDate passed) or budget exhausted
  REJECTED
}

model Campaign {
  id              String              @id @default(cuid())
  userId          String
  objective       CampaignObjective
  title           String
  description     String
  imageUrl        String?
  ctaUrl          String?
  targetType      CampaignTargetType
  targetPincode   String?
  targetStates    String[]
  targetLatitude  Float?
  targetLongitude Float?
  targetRadiusKm  Float?
  budgetInPaise   Int
  status          CampaignStatus      @default(DRAFT)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime            @default(now())

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments    CampaignPayment[]
  impressions CampaignImpression[]

  @@index([status])
  @@index([targetPincode])
}

model CampaignPayment {
  id                String   @id @default(cuid())
  campaignId        String
  razorpayLinkId    String   @unique
  razorpayPaymentId String?
  amountInPaise     Int
  status            String   @default("created")
  createdAt         DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignImpression {
  id         String   @id @default(cuid())
  campaignId String
  userId     String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}
