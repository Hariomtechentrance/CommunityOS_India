# Postgres connection string from Neon or Supabase (cloud dev DB)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT signing secret - use a long random string
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# App
PORT=3000

# Comma-separated list of browser origins allowed to call this API / connect
# to its sockets (e.g. "https://community-os-india.web.app,http://localhost:5000").
# Leave unset for local dev to allow any origin. Always set this in
# production - native Android/iOS clients aren't affected either way, since
# they don't send a browser Origin header.
CORS_ALLOWED_ORIGINS=""

# Firebase Admin SDK - from Project Settings -> Service Accounts -> Generate new
# private key. FIREBASE_PRIVATE_KEY should have its newlines escaped as \n.
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Maps Platform - server-side key for the Geocoding API (unrestricted/
# server-only). A separate, HTTP-referrer-restricted key goes in the Flutter
# web app for the Maps JavaScript API instead.
GOOGLE_MAPS_SERVER_API_KEY="your-server-side-maps-api-key"

# Public URL of the deployed frontend - used to build the Razorpay payment
# link's callback_url (where the browser returns to after paying).
APP_URL="https://community-os-india.web.app"

# Razorpay (ad campaign payments) - from the Razorpay Dashboard -> Settings
# -> API Keys (Key ID + Key Secret), and Settings -> Webhooks (create a
# webhook pointing at POST {your-backend}/campaigns/webhook/razorpay,
# subscribed to the "payment_link.paid" event, to get its Webhook Secret).
# Ad checkout is disabled with a clear error until these are set.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
