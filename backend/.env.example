# Postgres connection string from Neon or Supabase (cloud dev DB)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT signing secret - use a long random string
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="30d"

# App
PORT=3000

# Firebase Admin SDK - from Project Settings -> Service Accounts -> Generate new
# private key. FIREBASE_PRIVATE_KEY should have its newlines escaped as \n.
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Maps Platform - server-side key for the Geocoding API (unrestricted/
# server-only). A separate, HTTP-referrer-restricted key goes in the Flutter
# web app for the Maps JavaScript API instead.
GOOGLE_MAPS_SERVER_API_KEY="your-server-side-maps-api-key"
